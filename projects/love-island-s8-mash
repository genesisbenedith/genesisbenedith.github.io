];

/* ── Raw options for display in elim phase ───────────── */
const RAW_OPTS = {
  home:    ["Fiji Villa Together", "Studio Apartment", "A Shack", "Casa Amor Mansion"],
  kids:    ["No Kids", "1 Baby", "2 Babies", "3 Babies"],
  vibe:    ["The Dramatic One", "The Loyal One", "The Sneaky Flirt", "The Villain"],
  fate:    ["$100K Winners", "Dumped Week 1", "Casa Amor Betrayal", "Nation's Fave"],
};

/* ══════════════════════════════════════════════════════
   MAIN COMPONENT
══════════════════════════════════════════════════════ */
export default function App() {
  const [phase,    setPhase]    = useState("welcome");
  const [userName, setUserName] = useState("");
  const [picks,    setPicks]    = useState([]);   // up to 4 islander names
  const [tVal,     setTVal]     = useState(0);    // spiral animation value
  const [stopped,  setStopped]  = useState(false);
  const [magic,    setMagic]    = useState(null);
  const [mashData, setMashData] = useState(null);
  const [elimSet,  setElimSet]  = useState(new Set());
  const [stepIdx,  setStepIdx]  = useState(0);
  const [copied,   setCopied]   = useState(false);

  const rafRef = useRef(null);
  const tRef   = useRef(0);

  /* ── Spiral animation loop ── */
  useEffect(() => {
    if (phase !== "spiral" || stopped) return;
    const tick = () => {
      tRef.current = Math.min(tRef.current + 0.038, 40);
      setTVal(tRef.current);
      rafRef.current = requestAnimationFrame(tick);
    };
    rafRef.current = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(rafRef.current);
  }, [phase, stopped]);

  const stopSpiral = () => {
    cancelAnimationFrame(rafRef.current);
    setStopped(true);
    const m = Math.max(3, Math.min(8, Math.round(tRef.current / (2 * Math.PI))));
    setMagic(m || 4);
  };

  const startElim = () => {
    const data = runMASH(picks, magic);
    setMashData(data);
    setElimSet(new Set());
    setStepIdx(0);
    setPhase("elim");
  };

  /* ── Elimination step timer ── */
  useEffect(() => {
    if (phase !== "elim" || !mashData) return;
    if (stepIdx >= mashData.steps.length) {
      const t = setTimeout(() => setPhase("result"), 900);
      return () => clearTimeout(t);
    }
    const t = setTimeout(() => {
      setElimSet(prev => new Set([...prev, mashData.steps[stepIdx]]));
      setStepIdx(s => s + 1);
    }, 255);
    return () => clearTimeout(t);
  }, [phase, stepIdx, mashData]);

  const togglePick = name => setPicks(prev =>
    prev.includes(name) ? prev.filter(n => n !== name) :
    prev.length < 4     ? [...prev, name]               : prev
  );

  const resetAll = () => {
    setPhase("welcome"); setUserName(""); setPicks([]);
    setTVal(0); setStopped(false); setMagic(null);
    setMashData(null); setElimSet(new Set()); setStepIdx(0);
    tRef.current = 0;
  };

  /* ── Shared style tokens ── */
  const S = {
    page: {
      minHeight: "100vh",
      background: "linear-gradient(160deg, #060414 0%, #160838 55%, #061510 100%)",
      fontFamily: "'Segoe UI', system-ui, -apple-system, sans-serif",
      color: "#fff",
      display: "flex",
      alignItems: "center",
      justifyContent: "center",
      padding: "24px 16px",
    },
    card: (wide) => ({
      background: "rgba(255,255,255,0.055)",
      backdropFilter: "blur(28px)",
      WebkitBackdropFilter: "blur(28px)",
      borderRadius: "28px",
      padding: "32px 28px",
      width: "100%",
      maxWidth: wide ? "580px" : "500px",
      border: "1px solid rgba(255,107,157,0.22)",
      boxShadow: "0 32px 80px rgba(0,0,0,0.7), inset 0 1px 0 rgba(255,255,255,0.08)",
    }),
    h1: {
      fontSize: "clamp(1.7rem,5vw,2.3rem)",
      fontWeight: 900,
      background: "linear-gradient(90deg, #FF6B9D 0%, #FFD166 100%)",
      WebkitBackgroundClip: "text",
      WebkitTextFillColor: "transparent",
      textAlign: "center",
      margin: "0 0 6px",
      lineHeight: 1.15,
    },
    sub: {
      textAlign: "center",
      color: "#9580c0",
      fontSize: "0.76rem",
      letterSpacing: "0.13em",
      textTransform: "uppercase",
      margin: "0 0 22px",
    },
    textInput: {
      width: "100%",
      boxSizing: "border-box",
      background: "rgba(255,255,255,0.07)",
      border: "2px solid rgba(255,107,157,0.3)",
      borderRadius: "14px",
      color: "#fff",
      fontSize: "1.05rem",
      padding: "13px 16px",
      outline: "none",
      marginBottom: "14px",
      fontFamily: "inherit",
    },
    primaryBtn: (disabled) => ({
      display: "block",
      width: "100%",
      background: disabled
        ? "rgba(255,255,255,0.07)"
        : "linear-gradient(90deg, #FF6B9D, #FF8C6B)",
      border: "none",
      borderRadius: "50px",
      color: disabled ? "rgba(255,255,255,0.22)" : "#fff",
      fontWeight: 700,
      fontSize: "1rem",
      padding: "15px",
      cursor: disabled ? "not-allowed" : "pointer",
      letterSpacing: "0.04em",
      marginTop: "6px",
      fontFamily: "inherit",
      transition: "opacity 0.15s",
    }),
    ghostBtn: {
      display: "block",
      width: "100%",
      background: "rgba(255,255,255,0.06)",
      border: "1px solid rgba(255,255,255,0.12)",
      borderRadius: "50px",
      color: "rgba(255,255,255,0.55)",
      fontWeight: 600,
      fontSize: "0.95rem",
      padding: "13px",
      cursor: "pointer",
      letterSpacing: "0.04em",
      marginTop: "10px",
      fontFamily: "inherit",
    },
    islCard: (sel) => ({
      background: sel ? "rgba(255,107,157,0.18)" : "rgba(255,255,255,0.04)",
      border: `2px solid ${sel ? "#FF6B9D" : "rgba(255,255,255,0.08)"}`,
      borderRadius: "16px",
      padding: "14px 8px",
      textAlign: "center",
      cursor: "pointer",
      transition: "all 0.15s",
      position: "relative",
      userSelect: "none",
    }),
    chip: (out) => ({
      padding: "7px 13px",
      borderRadius: "20px",
      fontSize: "0.83rem",
      fontWeight: 500,
      background: out ? "rgba(255,255,255,0.02)" : "rgba(255,107,157,0.11)",
      border: `1px solid ${out ? "rgba(255,255,255,0.05)" : "rgba(255,107,157,0.3)"}`,
      color: out ? "rgba(255,255,255,0.18)" : "#fff",
      textDecoration: out ? "line-through" : "none",
      transition: "all 0.35s ease",
    }),
    resultRow: {
      background: "rgba(255,107,157,0.07)",
      border: "1px solid rgba(255,107,157,0.2)",
      borderRadius: "16px",
      padding: "14px 18px",
      display: "flex",
      alignItems: "center",
      gap: "14px",
      marginBottom: "10px",
    },
  };

  /* ════════════════ WELCOME ════════════════ */
  if (phase === "welcome") return (
    <div style={S.page}>
      <div style={S.card(false)}>
        <div style={{ fontSize: "3rem", textAlign: "center", marginBottom: "6px" }}>🌴</div>
        <h1 style={S.h1}>Love Island MASH</h1>
        <p style={S.sub}>Season 8  ·  Villa Edition  ·  Fiji 2026</p>
        <p style={{ color: "#b0a0d8", textAlign: "center", lineHeight: 1.7, fontSize: "0.94rem", margin: "0 0 24px" }}>
          Spin the spiral. Find out who you'll couple up with, where you'll live, and what fate the villa has sealed for you. 🌊
        </p>
        <input
          style={S.textInput}
          placeholder="Your name, babe 💅"
          value={userName}
          onChange={e => setUserName(e.target.value)}
          onKeyDown={e => e.key === "Enter" && userName.trim() && setPhase("pick")}
        />
        <button
          style={S.primaryBtn(!userName.trim())}
          disabled={!userName.trim()}
          onClick={() => setPhase("pick")}
