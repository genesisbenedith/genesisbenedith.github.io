        <h1 style={S.h1}>Who Gets Your Text? 💬</h1>
        <p style={S.sub}>Pick exactly 4 islanders you'd couple up with</p>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "9px", marginBottom: "16px" }}>
          {ISLANDERS.map(({ name, emoji, from }) => {
            const sel = picks.includes(name);
            return (
              <div key={name} style={S.islCard(sel)} onClick={() => togglePick(name)}>
                {sel && (
                  <div style={{ position: "absolute", top: "6px", right: "8px", fontSize: "0.68rem", color: "#FF6B9D", fontWeight: 800 }}>✓</div>
                )}
                <div style={{ fontSize: "1.55rem" }}>{emoji}</div>
                <div style={{ fontSize: "0.86rem", fontWeight: 700, marginTop: "5px", lineHeight: 1.2 }}>{name}</div>
                <div style={{ fontSize: "0.63rem", color: "#9580c0", marginTop: "3px" }}>{from}</div>
              </div>
            );
          })}
        </div>
        <p style={{ color: picks.length === 4 ? "#FFD166" : "#9580c0", textAlign: "center", fontSize: "0.87rem", margin: "0 0 10px", transition: "color 0.2s" }}>
          {picks.length}/4 selected{picks.length === 4 ? " — ready to spin! 🔥" : ""}
        </p>
        <button style={S.primaryBtn(picks.length !== 4)} disabled={picks.length !== 4} onClick={() => setPhase("spiral")}>
          Seal My Fate ✨
        </button>
      </div>
    </div>
  );

  /* ════════════════ SPIRAL ════════════════ */
  if (phase === "spiral") {
    const cx = 140, cy = 140;
    const path = buildSpiralPath(tVal, cx, cy);
    return (
      <div style={S.page}>
        <div style={S.card(false)}>
          <h1 style={S.h1}>Draw Your Spiral 🌀</h1>
          <p style={S.sub}>
            {stopped ? `Magic number: ${magic}` : "Watch it grow… then stop it!"}
          </p>
          <div style={{ display: "flex", justifyContent: "center", margin: "4px 0 20px" }}>
            <svg
              width="280" height="280" viewBox="0 0 280 280"
              style={{ filter: "drop-shadow(0 0 18px rgba(255,107,157,0.35))" }}
            >
              <defs>
                <linearGradient id="spiralGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stopColor="#FF6B9D" />
                  <stop offset="100%" stopColor="#FFD166" />
                </linearGradient>
              </defs>
              <path
                d={path}
                fill="none"
                stroke="url(#spiralGrad)"
                strokeWidth="2.5"
                strokeLinecap="round"
                strokeLinejoin="round"
              />
              {stopped && (
                <text
                  x="140" y="158" textAnchor="middle"
                  fill="#FFD166" fontSize="54" fontWeight="900"
                  fontFamily="system-ui"
                  style={{ filter: "drop-shadow(0 0 12px rgba(255,209,102,0.55))" }}
                >
                  {magic}
                </text>
              )}
            </svg>
          </div>
          {!stopped ? (
            <button style={S.primaryBtn(false)} onClick={stopSpiral}>🛑 STOP THE SPIRAL</button>
          ) : (
            <>
              <p style={{ color: "#b0a0d8", textAlign: "center", fontSize: "0.9rem", margin: "0 0 16px", lineHeight: 1.6 }}>
                Every <strong style={{ color: "#FFD166" }}>#{magic}</strong> option gets crossed out. Ready to see your fate?
              </p>
              <button style={S.primaryBtn(false)} onClick={startElim}>Reveal My Fate 🌴</button>
            </>
          )}
        </div>
      </div>
    );
  }

  /* ════════════════ ELIMINATION ════════════════ */
  if (phase === "elim" && mashData) {
    return (
      <div style={S.page}>
        <div style={S.card(true)}>
          <h1 style={S.h1}>Crossing Off Options... ✂️</h1>
          <p style={S.sub}>Magic number: {magic}</p>
          <div style={{ display: "flex", flexDirection: "column", gap: "14px", marginTop: "12px" }}>
            {CAT_META.map(({ key, label, icon }) => {
              // Get display labels & raw values for this category
              const displayPairs = key === "partner"
                ? picks.map(n => ({ display: `${emojiOf(n)} ${n}`, raw: n }))
                : RAW_OPTS[key].map(v => ({ display: v, raw: v }));

              return (
                <div key={key}>
                  <div style={{ fontSize: "0.71rem", color: "#9580c0", textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: "8px" }}>
                    {icon} {label}
                  </div>
                  <div style={{ display: "flex", flexWrap: "wrap", gap: "8px" }}>
                    {displayPairs.map(({ display, raw }) => {
                      const itemIdx = mashData.items.findIndex(it => it.cat === key && it.val === raw);
                      const out = elimSet.has(itemIdx);
                      return <span key={display} style={S.chip(out)}>{display}</span>;
                    })}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    );
  }

  /* ════════════════ RESULT ════════════════ */
  if (phase === "result" && mashData) {
    const res = mashData.result;
    const shareText = [
      "🌴 My Love Island MASH (S8 2026)",
      "",
      `💑 Partner: ${res.partner}`,
      `🏠 Home: ${res.home}`,
      `👶 Kids: ${res.kids}`,
      `🎭 Vibe: ${res.vibe}`,
      `🏆 Fate: ${res.fate}`,
      "",
      "What's your fate? 🌊",
    ].join("\n");

    return (
      <div style={S.page}>
        <div style={S.card(false)}>
          <div style={{ fontSize: "2.6rem", textAlign: "center", marginBottom: "4px" }}>🎉</div>
          <h1 style={S.h1}>{userName}'s Love Island Fate</h1>
          <p style={S.sub}>The villa has spoken 🌴</p>
          <div style={{ margin: "16px 0 20px" }}>
            {CAT_META.map(({ key, label, icon }) => {
              const raw = res[key];
              const display = key === "partner" ? `${emojiOf(raw)} ${raw}` : raw;
              return (
                <div key={key} style={S.resultRow}>
                  <span style={{ fontSize: "1.5rem", flexShrink: 0 }}>{icon}</span>
                  <div>
                    <div style={{ fontSize: "0.67rem", color: "#9580c0", textTransform: "uppercase", letterSpacing: "0.08em" }}>
                      {label}
                    </div>
                    <div style={{ fontSize: "1.05rem", fontWeight: 700, color: "#FFD166", marginTop: "3px" }}>
                      {display}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          <button
            style={S.primaryBtn(false)}
            onClick={() => {
              navigator.clipboard.writeText(shareText).catch(() => {});
              setCopied(true);
              setTimeout(() => setCopied(false), 2200);
            }}
          >
            {copied ? "✅ Copied!" : "📋 Share Your Result"}
          </button>
          <button style={S.ghostBtn} onClick={resetAll}>Play Again 🔄</button>
        </div>
      </div>
    );
  }

  return null;
}