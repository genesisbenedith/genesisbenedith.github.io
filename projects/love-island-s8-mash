/* ── Spiral SVG path ─────────────────────────────────── */
function buildSpiralPath(t, cx, cy) {
  if (t < 0.05) return `M${cx},${cy}`;
  const a = 3;
  const pts = Math.max(2, Math.floor(t * 80));
  let d = "";
  for (let i = 0; i <= pts; i++) {
    const s = t * (i / pts);
    const x = (cx + a * s * Math.cos(s)).toFixed(1);
    const y = (cy + a * s * Math.sin(s)).toFixed(1);
    d += i === 0 ? `M${x},${y}` : `L${x},${y}`;
  }
  return d;
}

/* ── MASH elimination algorithm ─────────────────────── */
function runMASH(partnerOpts, n) {
  const CATS = {
    partner: partnerOpts,
    home:    ["Fiji Villa Together", "Studio Apartment", "A Shack", "Casa Amor Mansion"],
    kids:    ["No Kids", "1 Baby", "2 Babies", "3 Babies"],
    vibe:    ["The Dramatic One", "The Loyal One", "The Sneaky Flirt", "The Villain"],
    fate:    ["$100K Winners", "Dumped Week 1", "Casa Amor Betrayal", "Nation's Fave"],
  };
  const keys = Object.keys(CATS);

  // Build round-robin flat list (4 rounds × 5 cats = 20 items)
  const items = [];
  for (let i = 0; i < 4; i++)
    for (const k of keys)
      items.push({ cat: k, val: CATS[k][i] });

  const elim = new Array(items.length).fill(false);
  const steps = [];

  const rem  = k => items.filter((it, i) => it.cat === k && !elim[i]).length;
  const skip = i => elim[i] || rem(items[i].cat) <= 1;
  const done = () => keys.every(k => rem(k) <= 1);

  let pos = 0;
  for (let iter = 0; iter < 300 && !done(); iter++) {
    let count = 0, cur = pos, safety = 0;
    while (safety++ < 200) {
      if (!skip(cur)) { count++; if (count === n) break; }
      cur = (cur + 1) % items.length;
    }
    if (safety >= 200) break;
    elim[cur] = true;
    steps.push(cur);
    pos = (cur + 1) % items.length;
  }

  const result = {};
  for (const k of keys) {
    const i = items.findIndex((it, idx) => it.cat === k && !elim[idx]);
    result[k] = i >= 0 ? items[i].val : null;
  }
  return { items, steps, result };
}

/* ── Category metadata ───────────────────────────────── */
const CAT_META = [
